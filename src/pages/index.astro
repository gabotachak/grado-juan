---
import Layout from '../layouts/Layout.astro';

const NOMBRE = 'Juan Diego Gallego Tachack';
const MAPS_URL = 'https://maps.app.goo.gl/ds4NkV1i2Ap3Spvv9';
const TELEFONO = '573057126176';
const MENSAJE_WHATSAPP = [
  '¡Hola! Confirmo mi asistencia al grado de Juan Diego 🎓',
  '',
  '📅 Sábado 11 de julio',
  '🕐 1:00 p.m.',
  '📍 Conjunto Residencial Obelisco, Salón Comunal',
  'Calle 24A # 57 - 69',
  MAPS_URL,
  '',
  '¡Nos vemos pronto!',
].join('\n');

const WHATSAPP_URL = `https://wa.me/${TELEFONO}?text=${encodeURIComponent(MENSAJE_WHATSAPP)}`;

const BATA_IMG = `${import.meta.env.BASE_URL}juan-bata.jpg`;
const BIRRETE_IMG = `${import.meta.env.BASE_URL}juan-birrete.jpg`;
---

<Layout
  title="🎓 Grado de Médico de Juan Diego — ¡Estás invitado!"
  description="📅 Sábado 11 de julio · 🕐 1:00 p.m. · 📍 Conjunto Residencial Obelisco, Calle 24A # 57 - 69. Toca para ver el mapa y confirmar tu asistencia."
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <svg
        class="hero-cap"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M12 3 1 8l11 5 9-4.09V15h2V8L12 3z" />
        <path d="M5 11.18V15c0 1.66 3.13 3 7 3s7-1.34 7-3v-3.82l-7 3.18-7-3.18z" />
      </svg>

      <p class="invite-lead">Con mucha alegría, te invitamos a la celebración del&hellip;</p>
      <div class="ornament"><span></span></div>

      <div class="photo-single">
        <div class="frame">
          <div class="frame-inner">
            <img src={BATA_IMG} alt={NOMBRE} width="1086" height="1448" fetchpriority="high" />
          </div>
        </div>
      </div>

      <h1 class="hero-name">
        <span class="hero-name-prefix">Grado de</span><br />
        <span id="hero-name-text" class="hero-name-text">{NOMBRE}</span>
      </h1>
      <p class="hero-subtitle">como <strong>Médico</strong>.</p>

      <div class="ornament"><span></span></div>

      <p class="hero-date">Sábado 11 de julio de 2026 &middot; 1:00 p.m.</p>
      <p class="hero-countdown" id="countdown" hidden></p>

      <a class="scroll-cue" href="#detalles" aria-label="Desliza para ver más">
        <span>Descubre los detalles</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 4v16m0 0l-6-6m6 6l6-6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </section>

  <!-- MENSAJE -->
  <section class="mensaje">
    <div class="ornament"><span></span></div>
    <div class="mensaje-texto reveal">
      <p>
        Para nosotros, es muy especial contar con tu presencia para compartir este gran
        logro, fruto de esfuerzo, aprendizaje y grandes experiencias.
      </p>
      <p>
        Un gran sueño que construimos juntos; no hay mejor forma de celebrar este momento
        tan significativo para nuestra amada familia, rodeado de las personas que le han
        acompañado en cada proceso.
      </p>
    </div>

    <div class="photo-single reveal">
      <div class="frame">
        <div class="frame-inner">
          <img src={BIRRETE_IMG} alt={`${NOMBRE} con birrete`} width="1200" height="1600" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>

    <div class="ornament"><span></span></div>
  </section>

  <!-- DETALLES -->
  <section id="detalles" class="detalles">
    <p class="section-title">Detalles del evento</p>

    <div class="detalles-card reveal">
      <div class="detalle-item">
        <div class="detalle-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="5" width="18" height="16" rx="2" />
            <path d="M16 3v4M8 3v4M3 10h18" stroke-linecap="round" />
          </svg>
        </div>
        <div>
          <p class="detalle-label">Fecha</p>
          <p class="detalle-valor">Sábado 11 de julio de 2026</p>
        </div>
      </div>

      <div class="detalle-item">
        <div class="detalle-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="9" />
            <path d="M12 7v5l3.5 2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <div>
          <p class="detalle-label">Hora</p>
          <p class="detalle-valor">1:00 p.m.</p>
        </div>
      </div>

      <div class="detalle-item">
        <div class="detalle-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path
              d="M12 21s-7-6.3-7-11.5A7 7 0 0119 9.5C19 14.7 12 21 12 21z"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <circle cx="12" cy="9.5" r="2.4" />
          </svg>
        </div>
        <div>
          <p class="detalle-label">Lugar</p>
          <p class="detalle-valor">Conjunto Residencial Obelisco &mdash; Salón Comunal</p>
          <p class="detalle-direccion">Calle 24A # 57 - 69</p>
          <a class="btn btn-outline mapa-btn" href={MAPS_URL} target="_blank" rel="noopener noreferrer">
            Cómo llegar
          </a>
        </div>
      </div>

      <div class="detalle-item">
        <div class="detalle-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path
              d="M8 3 3 6v4h3v11h12V10h3V6l-5-3-2 2h-4z"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </div>
        <div>
          <p class="detalle-label">Protocolo</p>
          <p class="detalle-valor">Traje casual</p>
        </div>
      </div>

      <div class="detalle-item">
        <div class="detalle-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="M3 7l9 6 9-6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <div>
          <p class="detalle-valor">Lluvia de sobres</p>
        </div>
      </div>
    </div>

    <div class="confirmar-wrap reveal">
      <a class="btn btn-whatsapp" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.83.5 3.53 1.36 4.99L2 22l5.25-1.38a9.9 9.9 0 004.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91C21.96 6.45 17.5 2 12.04 2zm5.8 14.03c-.24.68-1.4 1.3-1.93 1.38-.5.08-1.12.11-1.8-.11-.42-.13-.95-.3-1.63-.6-2.87-1.24-4.75-4.13-4.9-4.32-.14-.2-1.17-1.56-1.17-2.98 0-1.42.74-2.11 1.01-2.4.27-.29.58-.36.78-.36.19 0 .39 0 .55.01.18.01.42-.07.65.5.24.58.81 2.01.88 2.16.07.15.12.32.02.52-.1.2-.15.32-.3.49-.15.17-.31.38-.44.51-.15.15-.3.31-.13.6.17.29.76 1.25 1.63 2.03 1.12 1 2.06 1.31 2.35 1.46.29.15.46.13.63-.07.17-.2.72-.84.91-1.13.19-.29.38-.24.63-.14.26.1 1.66.78 1.94.92.29.15.48.22.55.34.07.13.07.72-.17 1.4z"
          />
        </svg>
        Confirmar asistencia
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="ornament"><span></span></div>
    <p class="footer-firma">🎓 &nbsp;Familia Gallego Tachack&nbsp; 🎓</p>
  </footer>

  <style>
    .hero {
      min-height: 100svh;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding-top: 3rem;
      padding-bottom: 2rem;
    }

    .hero-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.4rem;
      max-width: 640px;
      width: 100%;
      min-width: 0;
    }

    .hero-cap {
      width: 46px;
      height: 46px;
      color: var(--gold);
      filter: drop-shadow(0 4px 14px rgba(212, 175, 55, 0.4));
    }

    .photo-single {
      width: min(64vw, 320px);
      margin: 1.2rem auto 1.4rem;
    }

    .photo-single .frame-inner {
      aspect-ratio: 3 / 4;
    }

    @media (max-width: 480px) {
      .hero {
        padding-top: 1.25rem;
        padding-bottom: 1rem;
      }

      .photo-single {
        margin: 0.6rem auto 0.8rem;
      }

      .hero .ornament {
        margin: 0.7rem auto;
      }

      .scroll-cue {
        margin-top: 1rem;
      }
    }

    /* Viewports cortos (Safari iPhone con barra visible): recuperar el alto
       que ocupa el contador para que el scroll cue no quede fuera de pantalla */
    @media (max-width: 480px) and (max-height: 760px) {
      .hero {
        padding-top: 0.7rem;
      }

      .hero-inner {
        gap: 0.25rem;
      }

      .invite-lead {
        margin-top: 0;
      }

      .hero-cap {
        width: 30px;
        height: 30px;
      }

      .hero .ornament {
        margin: 0.45rem auto;
      }

      .photo-single {
        width: min(43vw, 185px);
        margin: 0.4rem auto 0.55rem;
      }

      .hero-date {
        margin-top: 0.15rem;
      }

      .hero-countdown {
        margin-top: 0.4rem;
      }

      .scroll-cue {
        margin-top: 0.4rem;
      }
    }

    .hero-name {
      max-width: 100%;
      font-size: clamp(2.1rem, 6vw, 3.2rem);
      letter-spacing: 0.01em;
      line-height: 1.15;
      background: linear-gradient(135deg, var(--white), var(--gold-light) 60%, var(--gold));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-name-prefix {
      display: inline-block;
      font-size: 0.5em;
      font-weight: 500;
      letter-spacing: 0.04em;
    }

    .hero-name-text {
      display: inline-block;
      white-space: nowrap;
      font-size: clamp(1.05rem, 7vw, 3.2rem);
    }

    .hero-subtitle {
      font-family: var(--font-display);
      font-style: italic;
      font-size: clamp(1.2rem, 3vw, 1.6rem);
      color: var(--ivory);
      opacity: 0.9;
    }

    .hero-subtitle strong {
      font-weight: 700;
      color: var(--gold-light);
    }

    .invite-lead {
      font-family: var(--font-display);
      font-style: italic;
      font-size: clamp(1.1rem, 2.6vw, 1.4rem);
      color: var(--ivory);
      opacity: 0.85;
      margin-top: 0.4rem;
    }

    .hero-date {
      font-family: var(--font-label);
      letter-spacing: 0.06em;
      color: var(--gold-light);
      font-size: 1rem;
      margin-top: 0.3rem;
    }

    .hero-countdown {
      font-family: var(--font-label);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--gold-light);
      border: 1px solid var(--gold-soft);
      border-radius: 999px;
      padding: 0.3rem 0.95rem;
      margin-top: 0.55rem;
      background: rgba(212, 175, 55, 0.07);
    }

    .scroll-cue {
      margin-top: 2.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
      text-decoration: none;
      color: rgba(248, 244, 233, 0.6);
      font-family: var(--font-label);
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      animation: floaty 2.4s ease-in-out infinite;
    }

    @keyframes floaty {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(6px); }
    }

    .mensaje {
      padding-top: 3rem;
      padding-bottom: 3rem;
      max-width: 680px;
    }

    .mensaje-texto {
      text-align: center;
    }

    .mensaje-texto p {
      font-size: 1.25rem;
      line-height: 1.6;
      color: rgba(248, 244, 233, 0.9);
      margin-bottom: 1.2rem;
    }

    .mensaje-texto p:last-child {
      margin-bottom: 0;
    }

    .mensaje-texto strong {
      color: var(--gold-light);
      font-weight: 700;
    }

    @media (max-width: 480px) {
      .mensaje {
        padding-top: 2rem;
        padding-bottom: 2rem;
      }

      .mensaje-texto p {
        font-size: 1.1rem;
      }
    }

    .detalles {
      scroll-margin-top: 0.5rem;
    }

    .detalles-card {
      position: relative;
      background: linear-gradient(160deg, rgba(26, 63, 110, 0.45), rgba(10, 31, 61, 0.55));
      border: 1px solid var(--gold-soft);
      border-radius: 20px;
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.8rem;
      backdrop-filter: blur(6px);
    }

    .detalles-card::before,
    .detalles-card::after {
      content: '';
      position: absolute;
      width: 26px;
      height: 26px;
      pointer-events: none;
    }

    .detalles-card::before {
      top: 9px;
      left: 9px;
      border-top: 1px solid var(--gold);
      border-left: 1px solid var(--gold);
      border-top-left-radius: 12px;
    }

    .detalles-card::after {
      bottom: 9px;
      right: 9px;
      border-bottom: 1px solid var(--gold);
      border-right: 1px solid var(--gold);
      border-bottom-right-radius: 12px;
    }

    .detalle-item {
      display: flex;
      align-items: flex-start;
      gap: 1.2rem;
    }

    .detalle-icon {
      flex-shrink: 0;
      width: 52px;
      height: 52px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(212, 175, 55, 0.12);
      color: var(--gold-light);
      border: 1px solid var(--gold-soft);
    }

    .detalle-label {
      font-family: var(--font-label);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 0.72rem;
      color: var(--gold-light);
      margin-bottom: 0.25rem;
    }

    .detalle-valor {
      font-size: 1.3rem;
      color: var(--white);
      font-weight: 500;
    }

    .detalle-direccion {
      font-size: 1.05rem;
      color: rgba(248, 244, 233, 0.75);
    }

    .mapa-btn {
      margin-top: 0.8rem;
      padding: 0.6rem 1.3rem;
      font-size: 0.85rem;
    }

    .confirmar-wrap {
      display: flex;
      justify-content: center;
      margin-top: 2.2rem;
    }

    .footer {
      text-align: center;
      padding: 3rem 1.5rem 4rem;
      max-width: 600px;
      margin: 0 auto;
    }

    .footer-firma {
      font-family: var(--font-display);
      font-style: italic;
      color: var(--gold-light);
      font-size: 1.2rem;
    }

    :global(html.js) .reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }

    :global(html.js) .reveal.visible {
      opacity: 1;
      transform: none;
    }
  </style>

  <script>
    document.documentElement.classList.add('js');

    const countdown = document.getElementById('countdown');
    if (countdown) {
      const eventDay = new Date(2026, 6, 11);
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const days = Math.round((eventDay.getTime() - today.getTime()) / 86400000);
      if (days > 1) {
        countdown.textContent = `Faltan ${days} días`;
        countdown.hidden = false;
      } else if (days === 1) {
        countdown.textContent = '¡Es mañana!';
        countdown.hidden = false;
      } else if (days === 0) {
        countdown.textContent = '¡Es hoy!';
        countdown.hidden = false;
      }
    }

    const heroNameText = document.getElementById('hero-name-text');
    const heroName = document.querySelector('.hero-name');
    function fitHeroName() {
      if (!(heroNameText instanceof HTMLElement) || !(heroName instanceof HTMLElement)) return;
      heroNameText.style.fontSize = '';
      const available = heroName.clientWidth;
      const natural = heroNameText.scrollWidth;
      if (natural > available) {
        const currentSize = parseFloat(getComputedStyle(heroNameText).fontSize);
        heroNameText.style.fontSize = `${(currentSize * available * 0.985) / natural}px`;
      }
    }
    if (document.fonts?.ready) {
      document.fonts.ready.then(fitHeroName);
    }
    fitHeroName();
    window.addEventListener('resize', fitHeroName);

    const revealEls = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
      );
      revealEls.forEach((el) => observer.observe(el));
    } else {
      revealEls.forEach((el) => el.classList.add('visible'));
    }
  </script>
</Layout>
